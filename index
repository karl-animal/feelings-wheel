const notes={
  "Overwhelmed":"Often a sign you need to triage: what's actually urgent vs. what just feels urgent?",
  "Anxious":"Anxiety is typically about the future. Grounding in the present moment can interrupt the loop.",
  "Angry":"Anger often signals a boundary was crossed. Worth asking: what do you actually need here?",
  "Sad":"Sadness is a signal of attachment — you can only grieve what mattered.",
  "Ashamed":"Shame says 'I am bad.' Guilt says 'I did something bad.' They require different responses.",
  "Guilty":"Guilt can be healthy (motivating repair) or destructive (punishing without purpose). Worth distinguishing.",
  "Numb":"Numbness is often protection. The feelings are there — they're just on pause.",
  "Lonely":"Loneliness doesn't always mean being alone. You can feel it in a crowd, or even in a relationship.",
  "Hopeless":"Hopelessness often distorts time — what feels permanent rarely is.",
  "Furious":"Very high arousal states impair judgment. Cooling down before deciding or speaking usually helps.",
  "Betrayed":"Betrayal wounds trust, which is slow to rebuild and can't be forced.",
  "Jealous":"Jealousy often flags something you value and fear losing — worth examining what that is.",
  "Rejected":"Rejection is painful partly because social exclusion activates the same brain regions as physical pain.",
  "Grief":"Grief isn't linear. It doesn't follow stages on a schedule.",
  "Vulnerable":"Vulnerability isn't weakness. It's the cost of caring about anything.",
  "Confused":"Confusion before clarity is normal. It often means you're thinking carefully about something that matters.",
  "Embarrassed":"Embarrassment is almost always worse in your own head than in anyone else's.",
  "Curious":"Curiosity tends to crowd out anxiety. Hard to feel both fully at once.",
  "Excited":"High-arousal positive states are physiologically similar to anxiety. Naming it can help.",
  "Confident":"Confidence is often less about certainty and more about trusting your ability to adapt.",
  "Exhausted":"Rest is not laziness. Sustained output without recovery is just a slower form of breakdown.",
  "Stressed":"Stress itself isn't always bad — it's chronic, unrelieved stress that causes damage.",
  "Disappointed":"Disappointment is the gap between expectation and reality. Sometimes the expectation is the problem.",
};

let state={level:0,core:-1,sec:-1};
let hovered=null;
const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');

function lighten(hex,amt){
  let r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return '#'+[Math.min(255,r+amt),Math.min(255,g+amt),Math.min(255,b+amt)].map(x=>x.toString(16).padStart(2,'0')).join('');
}

function getSegments(){
  const segs=[];
  if(state.level===0){
    const total=wheel.reduce((s,c)=>s+c.children.length,0);
    let angle=-Math.PI/2;
    wheel.forEach((core,ci)=>{
      const span=(core.children.length/total)*2*Math.PI;
      segs.push({type:'core',ci,sa:angle,ea:angle+span,color:core.color,label:core.label,r0:R0,r1:R3});
      angle+=span;
    });
  } else if(state.level===1){
    const core=wheel[state.core];
    const n=core.children.length;
    const span=2*Math.PI/n;
    let angle=-Math.PI/2;
    core.children.forEach((sec,si)=>{
      segs.push({type:'sec',ci:state.core,si,sa:angle,ea:angle+span,color:lighten(core.color,40),label:sec.label,r0:R0,r1:R3});
      angle+=span;
    });
  } else if(state.level===2){
    const core=wheel[state.core];
    const sec=core.children[state.sec];
    const n=sec.children.length;
    const span=2*Math.PI/n;
    let angle=-Math.PI/2;
    sec.children.forEach((sp,spi)=>{
      segs.push({type:'sp',ci:state.core,si:state.sec,spi,sa:angle,ea:angle+span,color:lighten(core.color,70),label:sp,r0:R0,r1:R3});
      angle+=span;
    });
  }
  return segs;
}

function draw(){
  ctx.clearRect(0,0,W,W);
  const segs=getSegments();
  const isDark=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches;

  segs.forEach((seg,i)=>{
    const mid=(seg.sa+seg.ea)/2;
    const isHov=hovered===i;
    const r1=isHov?seg.r1+8:seg.r1;
    ctx.beginPath();
    ctx.moveTo(CX+seg.r0*Math.cos(seg.sa),CY+seg.r0*Math.sin(seg.sa));
    ctx.arc(CX,CY,r1,seg.sa,seg.ea);
    ctx.arc(CX,CY,seg.r0,seg.ea,seg.sa,true);
    ctx.closePath();
    ctx.fillStyle=seg.color;
    ctx.fill();
    ctx.strokeStyle=isDark?'rgba(0,0,0,0.5)':'rgba(255,255,255,0.8)';
    ctx.lineWidth=1.5;
    ctx.stroke();

    const textR=(seg.r0+r1)/2;
    const chars=seg.label.length;
    const fontSize=chars>10?10:chars>7?11:12;
    ctx.save();
    ctx.translate(CX,CY);
    ctx.rotate(mid+Math.PI/2);
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    ctx.font=`500 ${fontSize}px -apple-system,sans-serif`;
    ctx.fillStyle=isDark?'rgba(255,255,255,0.9)':'rgba(0,0,0,0.75)';
    const words=seg.label.split(' ');
    if(words.length===1){
      ctx.fillText(seg.label,0,-textR);
    } else {
      const l1=words.slice(0,Math.ceil(words.length/2)).join(' ');
      const l2=words.slice(Math.ceil(words.length/2)).join(' ');
      ctx.fillText(l1,0,-textR-6);
      ctx.fillText(l2,0,-textR+6);
    }
    ctx.restore();
  });

  ctx.beginPath();
  ctx.arc(CX,CY,R0,0,2*Math.PI);
  ctx.fillStyle=isDark?'#1a1a1a':'#ffffff';
  ctx.fill();
  ctx.strokeStyle=isDark?'rgba(255,255,255,0.15)':'rgba(0,0,0,0.1)';
  ctx.lineWidth=1;
  ctx.stroke();

  ctx.textAlign='center';
  ctx.textBaseline='middle';
  ctx.font=`500 11px -apple-system,sans-serif`;
  ctx.fillStyle=isDark?'rgba(255,255,255,0.4)':'rgba(0,0,0,0.35)';
  if(state.level===0) ctx.fillText('tap',CX,CY);
  else { ctx.fillText('back',CX,CY-7); ctx.font=`400 9px -apple-system,sans-serif`; ctx.fillText('to core',CX,CY+6); }
}

function getSegAt(x,y){
  const dx=x-CX,dy=y-CY;
  const r=Math.sqrt(dx*dx+dy*dy);
  if(r<R0||r>R3+10) return -1;
  let angle=Math.atan2(dy,dx);
  const segs=getSegments();
  for(let i=0;i<segs.length;i++){
    let sa=segs[i].sa,ea=segs[i].ea,a=angle;
    while(a<sa) a+=2*Math.PI;
    if(a<=ea) return i;
  }
  return -1;
}

canvas.addEventListener('mousemove',e=>{
  const rect=canvas.getBoundingClientRect();
  const sx=canvas.width/rect.width,sy=canvas.height/rect.height;
  const x=(e.clientX-rect.left)*sx,y=(e.clientY-rect.top)*sy;
  const dx=x-CX,dy=y-CY,r=Math.sqrt(dx*dx+dy*dy);
  hovered=getSegAt(x,y);
  canvas.style.cursor=(r<R0||hovered>=0)?'pointer':'default';
  draw();
});
canvas.addEventListener('mouseleave',()=>{hovered=null;draw();});

function handleClick(cx,cy){
  const dx=cx-CX,dy=cy-CY,r=Math.sqrt(dx*dx+dy*dy);
  if(r<R0&&state.level>0){
    state={level:0,core:-1,sec:-1};
    document.getElementById('detail').style.display='none';
    document.getElementById('fw-sub').textContent='Click a segment to explore';
    hovered=null;draw();return;
  }
  const idx=getSegAt(cx,cy);
  if(idx<0) return;
  const segs=getSegments();
  const seg=segs[idx];
  if(seg.type==='core'){
    state={level:1,core:seg.ci,sec:-1};
    document.getElementById('fw-sub').textContent=wheel[seg.ci].label+' — pick a secondary emotion';
    document.getElementById('detail').style.display='none';
    hovered=null;draw();
  } else if(seg.type==='sec'){
    state={level:2,core:seg.ci,sec:seg.si};
    document.getElementById('fw-sub').textContent=wheel[seg.ci].children[seg.si].label+' — how specific?';
    document.getElementById('detail').style.display='none';
    hovered=null;draw();
  } else if(seg.type==='sp'){
    const cn=wheel[seg.ci].label,sn=wheel[seg.ci].children[seg.si].label,sp=seg.label;
    document.getElementById('detail-name').textContent=sp;
    document.getElementById('detail-path').textContent=cn+' › '+sn+' › '+sp;
    document.getElementById('detail-def').textContent=defs[sp]||'A distinct emotional state worth sitting with and naming.';
    const note=notes[sp]||notes[sn]||notes[cn]||'';
    const noteEl=document.getElementById('detail-note');
    noteEl.textContent=note; noteEl.style.display=note?'block':'none';
    const det=document.getElementById('detail');
    det.style.display='block';
    det.style.borderLeftColor=wheel[seg.ci].color;
    document.getElementById('fw-sub').textContent='';
  }
}

canvas.addEventListener('click',e=>{
  const rect=canvas.getBoundingClientRect();
  handleClick((e.clientX-rect.left)*(canvas.width/rect.width),(e.clientY-rect.top)*(canvas.height/rect.height));
});
canvas.addEventListener('touchstart',e=>{
  e.preventDefault();
  const rect=canvas.getBoundingClientRect();
  const t=e.touches[0];
  handleClick((t.clientX-rect.left)*(canvas.width/rect.width),(t.clientY-rect.top)*(canvas.height/rect.height));
},{passive:false});

function goBack(){
  if(state.level===2){state.level=1;state.sec=-1;document.getElementById('detail').style.display='none';document.getElementById('fw-sub').textContent=wheel[state.core].label+' — pick a secondary emotion';}
  else if(state.level===1){state={level:0,core:-1,sec:-1};document.getElementById('detail').style.display='none';document.getElementById('fw-sub').textContent='Click a segment to explore';}
  hovered=null;draw();
}

draw();
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change',draw);
</script>
</body>
</html>
