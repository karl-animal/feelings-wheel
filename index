<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feelings Wheel</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    --bg: #ffffff;
    --bg2: #f5f5f5;
    --text: #111111;
    --text2: #666666;
    --border: rgba(0,0,0,0.12);
    --border2: rgba(0,0,0,0.25);
    --radius-md: 8px;
    --radius-lg: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a1a;
      --bg2: #242424;
      --text: #f0f0f0;
      --text2: #999999;
      --border: rgba(255,255,255,0.12);
      --border2: rgba(255,255,255,0.25);
    }
  }
  body { font-family: var(--font-sans); background: var(--bg); color: var(--text); min-height: 100vh; }
  #fw { padding: 1.5rem 1rem; max-width: 640px; margin: 0 auto; }
  h1 { font-size: 20px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
  #fw-sub { font-size: 14px; color: var(--text2); margin-bottom: 1.25rem; min-height: 20px; }
  #canvas-wrap { display: flex; justify-content: center; margin-bottom: 1rem; }
  canvas { display: block; max-width: 100%; height: auto; cursor: default; }
  #detail {
    border: 0.5px solid var(--border);
    border-left: 3px solid #888;
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    background: var(--bg);
    display: none;
    margin-top: 0.5rem;
  }
  #detail-label { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 4px; }
  #detail-name { font-size: 26px; font-weight: 500; color: var(--text); margin-bottom: 8px; }
  #detail-path { font-size: 12px; color: var(--text2); margin-bottom: 12px; }
  #detail-def { font-size: 14px; color: var(--text); line-height: 1.6; margin-bottom: 12px; }
  #detail-note {
    font-size: 13px; color: var(--text2); font-style: italic; line-height: 1.5;
    border-left: 2px solid var(--border2); padding-left: 10px; display: none;
  }
  #back-btn {
    margin-top: 14px; background: none; border: 0.5px solid var(--border2);
    border-radius: var(--radius-md); padding: 7px 16px; font-size: 13px;
    color: var(--text); cursor: pointer; font-family: var(--font-sans);
  }
  #back-btn:hover { background: var(--bg2); }
</style>
</head>
<body>
<div id="fw">
  <h1>Feelings wheel</h1>
  <div id="fw-sub">Click a segment to explore</div>
  <div id="canvas-wrap"><canvas id="c" width="520" height="520"></canvas></div>
  <div id="detail">
    <div id="detail-label">You're feeling</div>
    <div id="detail-name"></div>
    <div id="detail-path"></div>
    <div id="detail-def"></div>
    <div id="detail-note"></div>
    <button id="back-btn" onclick="goBack()">Back</button>
  </div>
</div>
<script>
const W=520,CX=260,CY=260;
const R0=48,R3=255;

const wheel=[
  {label:"Angry",color:"#E05252",children:[
    {label:"Hurt",children:["Embarrassed","Betrayed","Dismissed","Ridiculed"]},
    {label:"Threatened",children:["Nervous","Exposed","Rejected","Inadequate"]},
    {label:"Hateful",children:["Resentful","Jealous","Contemptuous","Disgusted"]},
    {label:"Mad",children:["Furious","Hostile","Aggressive","Volatile"]},
    {label:"Critical",children:["Judgmental","Sarcastic","Cynical","Dismissive"]},
    {label:"Distant",children:["Withdrawn","Numb","Suspicious","Isolated"]},
  ]},
