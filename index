  ]},
  {label:"Bad",color:"#9A9080",children:[
    {label:"Bored",children:["Indifferent","Apathetic","Listless","Unfocused"]},
    {label:"Busy",children:["Rushed","Overwhelmed","Pressured","Stressed"]},
    {label:"Stressed",children:["Out of control","Fragile","Shaky","Tense"]},
    {label:"Tired",children:["Exhausted","Sleepy","Drained","Depleted"]},
