  {label:"Anticipation",color:"#D4804A",children:[
    {label:"Interested",children:["Curious","Engaged","Attentive","Fascinated"]},
    {label:"Impatient",children:["Eager","Tense","Restless","On edge"]},
    {label:"Hopeful",children:["Optimistic","Encouraged","Trusting","Expectant"]},
