    {label:"Playful",children:["Creative","Energetic","Silly","Amused"]},
    {label:"Content",children:["Peaceful","Fulfilled","Satisfied","Calm"]},
    {label:"Interested",children:["Curious","Fascinated","Engaged","Attentive"]},
    {label:"Proud",children:["Respected","Valued","Appreciated","Confident"]},
